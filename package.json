{
  "name": "with-react-native-web",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "start": "yarn dev"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "prisma": "7.4.1",
    "tsup": "^8.5.1",
    "turbo": "^2.7.3"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/db": [
        "packages/db/src"
      ],
      "@repo/types": [
        "packages/types/src"
      ]
    }
  },
  "dependencies": {
    "lucide-react-native": "^0.562.0",
    "minimatch": "^10.2.4",
    "nativewind": "^4.2.1",
    "react-native-svg": "^15.15.1"
  },
  "resolutions": {
    "@types/react": "18.3.14",
    "@types/react-dom": "18.3.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native-web": "0.21.2"
  }
}
