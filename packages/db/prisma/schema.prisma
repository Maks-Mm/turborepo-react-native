// packages/db/prisma/schema.prisma


datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  deadlines Deadline[]
  documents Document[]
  messages  Message[]
  consultingBookings ConsultingBooking[]
}

model Deadline {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  title    String
  dueDate  DateTime
}

model Document {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String
  status           String   @default("pending")
  fileUrl          String?
  analyzedByPython Boolean  @default(false)
  analysisResult   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Message {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  senderType  String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ConsultingBooking {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultantId String
  date         DateTime
  status       String   @default("pending")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([consultantId])
  @@index([date])
}

model TaxUpdate {
  id          String   @id @default(cuid())
  title       String
  content     String?
  category    String
  source      String
  sourceUrl   String?
  publishedAt DateTime
  createdAt   DateTime @default(now())
}